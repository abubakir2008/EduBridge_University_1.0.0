# Environment: development | production
# In production the app refuses to start with insecure secrets / non-secure cookies.
ENV=development

# PostgreSQL
POSTGRES_DB=edubridge
POSTGRES_USER=edubridge_university
POSTGRES_PASSWORD=your-strong-password
DATABASE_URL=postgresql://edubridge_university:your-strong-password@postgresql:5432/edubridge

# JWT — MUST be a strong random string of at least 32 chars.
# Generate one with:  python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=replace-with-a-32+char-random-secret-value
JWT_ACCESS_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=14

# Auth cookies (httpOnly). Set COOKIE_SECURE=true in production (HTTPS only).
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=

# MinIO — change credentials in production (defaults are rejected when ENV=production)
MINIO_ENDPOINT=minio:9000
MINIO_PUBLIC_URL=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false

# SMTP
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=SG.your-sendgrid-api-key
EMAIL_FROM=no-reply@edubridge.com

# Groq AI
GROQ_API_KEY=

# App
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
