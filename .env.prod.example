# ─────────────────────────────────────────────────────────────
# PRODUCTION ENVIRONMENT TEMPLATE
# Copy to server/.env and fill in real values.
# NEVER commit the actual .env to git.
# ─────────────────────────────────────────────────────────────

# PostgreSQL
POSTGRES_DB=edubridge
POSTGRES_USER=edubridge_university
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# DATABASE_URL — use URL-encoded password if it contains special chars (@, #, etc.)
# Example: Abubakiru@123 → Abubakiru%40123
DATABASE_URL=postgresql://edubridge_university:CHANGE_ME_STRONG_PASSWORD@postgresql:5432/edubridge

# JWT — generate with: python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET=CHANGE_ME_64_CHAR_RANDOM_HEX
JWT_ACCESS_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=14

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=CHANGE_ME_MINIO_USER
MINIO_SECRET_KEY=CHANGE_ME_MINIO_PASSWORD
MINIO_SECURE=false

# SMTP (SendGrid, Mailgun, etc.)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=SG.CHANGE_ME
EMAIL_FROM=no-reply@yourdomain.com

# CORS — your production domain(s), comma-separated
CORS_ORIGINS=https://yourdomain.com
